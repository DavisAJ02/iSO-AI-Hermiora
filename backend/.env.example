PORT=4000
# Same Supabase project as the Next.js app (hermiora/). JWTs from Google/email sign-in are issued here.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_or_publishable_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Client calls must send: Authorization: Bearer <supabase_session.access_token>
# (see requireAuth in backend/src/modules/auth/preHandler.ts)

# OpenAI (required for pipeline: chat, JSON steps, DALL·E 3, TTS)
OPENAI_API_KEY=
# Optional overrides
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=nova

# FFmpeg (must be installed on the host running the API — used after render_prep)
# FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\ffmpeg\bin\ffprobe.exe
# FFMPEG_PRESET=medium
# FFMPEG_CRF=20
