# Copy to `.env.local` — never commit `.env.local`.
# Put real keys only in `.env.local` (gitignored). This file is safe to commit: placeholders + docs only.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Supabase Dashboard → Authentication → URL configuration
# - Site URL: e.g. https://your-app.vercel.app (or http://localhost:3000 for dev)
# - Additional Redirect URLs: include BOTH:
#     http://localhost:3000/auth/callback
#     https://your-app.vercel.app/auth/callback
# Enable providers: Email, Google, Apple (Apple needs Services ID, Key, Team ID in Supabase).

# -----------------------------------------------------------------------------
# Google OAuth (Supabase is the OAuth client your app talks to)
# -----------------------------------------------------------------------------
# Supabase → Authentication → Providers → Google: enable; paste Google “Web client” ID + secret.
#
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web application):
#   Authorized redirect URIs — add ONLY Supabase’s callback (not your Vercel URL):
#     https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback
#   Authorized JavaScript origins — your app origins, e.g.:
#     http://localhost:3000
#     https://your-app.vercel.app
#
# Supabase “Redirect URLs” must still include your app callback (see block above), e.g.
#     https://your-app.vercel.app/auth/callback

# Optional — when the Next client calls the Fastify API (`backend/`), use this base URL + Bearer JWT
# NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-only (MaishaPay routes need this for DB writes / callbacks)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public URL of this app (MaishaPay callbackUrl + /api/payments/maisha/go). Use https + tunnel for real Maisha tests.
APP_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# MaishaPay — hosted checkout (https://www.maishapay.net/api_docs/en/Checkout.html)
# -----------------------------------------------------------------------------
# Do NOT paste real sandbox or live keys here. Copy this file to `.env.local` and fill values there.
#
# Preferred names (also supported: MAISHA_* — same values):
#   MAISHAPAY_PUBLIC_KEY / MAISHAPAY_SECRET_KEY / MAISHAPAY_BASE_URL / MAISHAPAY_GATEWAY_MODE
#
# Sandbox (demo / test)
#   MAISHA_GATEWAY_MODE=0  (or MAISHAPAY_GATEWAY_MODE=0)
#   Public key prefix:  MP-SBPK-…   (Developer section in merchant dashboard)
#   Secret key prefix:   MP-SBSK-…
#
# Live (production)
#   MAISHA_GATEWAY_MODE=1
#   Public key prefix:  MP-LIVEPK-…
#   Secret key prefix:   MP-LIVESK-…
#
# Mode and key pair must match (0 + sandbox keys, or 1 + live keys).
# -----------------------------------------------------------------------------
MAISHA_BASE_URL=https://marchand.maishapay.online/payment/vers1.0/merchant/checkout
MAISHA_GATEWAY_MODE=0
# Keys often contain $. Next.js expands $VAR in .env files — escape each literal $ as \ (backslash-dollar), e.g. MP-SBPK-abc\$def
MAISHA_PUBLIC_KEY=
MAISHA_SECRET_KEY=

MAISHAPAY_BASE_URL=https://marchand.maishapay.online/payment/vers1.0/merchant/checkout
MAISHAPAY_GATEWAY_MODE=
MAISHAPAY_PUBLIC_KEY=
MAISHAPAY_SECRET_KEY=

# Required for trusted MaishaPay server-to-server POST notifications.
# Configure the PSP/webhook sender to send this value as either:
#   Authorization: Bearer <secret>
#   x-maishapay-webhook-secret: <secret>
# Browser redirects without this secret only return the user to the status page;
# they must never activate subscriptions.
MAISHAPAY_WEBHOOK_SECRET=

# Integer CDF per 1 USD — required only if you use currency CDF in checkout
MAISHA_CDF_PER_USD=
# MAISHAPAY_CDF_PER_USD=

# Optional: UI-only estimate for CDF label (same idea as MAISHA_CDF_PER_USD)
# NEXT_PUBLIC_MAISHAPAY_CDF_PER_USD=2850

# -----------------------------------------------------------------------------
# Phase 7 AI integrations
# -----------------------------------------------------------------------------
# OpenAI powers real hook/script/scene/caption/image prompt generation.
OPENAI_API_KEY=
OPENAI_GENERATION_MODEL=gpt-4.1-mini
# Set to "off" to create placeholder projects without immediately calling OpenAI.
HERMIORA_REAL_GENERATION=on

# ElevenLabs is verified in Phase 7 and used for voice/audio generation in the media pipeline.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# TikTok sandbox/client credentials. Sandbox may verify auth without exposing live trends.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_SANDBOX=true
# Optional manual trend context injected into OpenAI prompts until live trend data is available.
TIKTOK_TREND_CONTEXT=
