# Copy to `.env.local` — never commit `.env.local`.
# Put real keys only in `.env.local` (gitignored). This file is safe to commit: placeholders + docs only.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key

# Server-only (MaishaPay routes need this for DB writes / callbacks)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Public URL of this app (MaishaPay callbackUrl + /api/payments/maisha/go). Use https + tunnel for real Maisha tests.
APP_BASE_URL=http://localhost:3000
# NEXT_PUBLIC_APP_BASE_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# MaishaPay — hosted checkout (https://www.maishapay.net/api_docs/en/Checkout.html)
# -----------------------------------------------------------------------------
# Do NOT paste real sandbox or live keys here. Copy this file to `.env.local` and fill values there.
#
# Sandbox (demo / test)
#   MAISHA_GATEWAY_MODE=0
#   Public key prefix:  MP-SBPK-…   (Developer section in merchant dashboard)
#   Secret key prefix:   MP-SBSK-…
#
# Live (production)
#   MAISHA_GATEWAY_MODE=1
#   Public key prefix:  MP-LIVEPK-…
#   Secret key prefix:   MP-LIVESK-…
#
# Mode and key pair must match (0 + sandbox keys, or 1 + live keys).
# -----------------------------------------------------------------------------
MAISHA_BASE_URL=https://marchand.maishapay.online/payment/vers1.0/merchant/checkout
MAISHA_GATEWAY_MODE=0
MAISHA_PUBLIC_KEY=
MAISHA_SECRET_KEY=

# Integer CDF per 1 USD — required only if you use currency CDF in checkout
MAISHA_CDF_PER_USD=

# Optional: UI-only estimate for CDF label (same idea as MAISHA_CDF_PER_USD)
# NEXT_PUBLIC_MAISHAPAY_CDF_PER_USD=2850
